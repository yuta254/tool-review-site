---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';
---
<BaseLayout title="パスワード生成ツール" description="安全でランダムなパスワードをその場で生成する無料ツール">
  <h1>パスワード生成ツール</h1>
  <p>ブラウザ内で完結し、生成したパスワードはサーバーに送信されません。</p>

  <AdSlot label="ツール上部広告" />

  <div class="card">
    <label>文字数: <span id="lengthLabel">16</span></label><br />
    <input type="range" id="length" min="6" max="64" value="16" style="width:100%;" /><br /><br />
    <label><input type="checkbox" id="upper" checked /> 英大文字 (A-Z)</label><br />
    <label><input type="checkbox" id="lower" checked /> 英小文字 (a-z)</label><br />
    <label><input type="checkbox" id="numbers" checked /> 数字 (0-9)</label><br />
    <label><input type="checkbox" id="symbols" /> 記号 (!@#$%など)</label><br /><br />
    <button id="generate" class="cta" style="border:none; cursor:pointer;">生成する</button>
  </div>

  <div class="card" style="margin-top:1rem;">
    <input type="text" id="result" readonly style="width:80%; padding:0.5rem; font-size:1.1rem; font-family:monospace;" />
    <button id="copy" style="padding:0.5rem 1rem;">コピー</button>
  </div>

  <AdSlot label="ツール下部広告" />

  <script>
    const lengthInput = document.getElementById('length') as HTMLInputElement;
    const lengthLabel = document.getElementById('lengthLabel')!;
    const upper = document.getElementById('upper') as HTMLInputElement;
    const lower = document.getElementById('lower') as HTMLInputElement;
    const numbers = document.getElementById('numbers') as HTMLInputElement;
    const symbols = document.getElementById('symbols') as HTMLInputElement;
    const result = document.getElementById('result') as HTMLInputElement;
    const generateBtn = document.getElementById('generate')!;
    const copyBtn = document.getElementById('copy')!;

    const SETS = {
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lower: 'abcdefghijklmnopqrstuvwxyz',
      numbers: '0123456789',
      symbols: '!@#$%^&*()-_=+[]{}',
    };

    function generate() {
      let charset = '';
      if (upper.checked) charset += SETS.upper;
      if (lower.checked) charset += SETS.lower;
      if (numbers.checked) charset += SETS.numbers;
      if (symbols.checked) charset += SETS.symbols;
      if (!charset) charset = SETS.lower;

      const len = parseInt(lengthInput.value, 10);
      const array = new Uint32Array(len);
      crypto.getRandomValues(array);
      let pw = '';
      for (let i = 0; i < len; i++) {
        pw += charset[array[i] % charset.length];
      }
      result.value = pw;
    }

    lengthInput.addEventListener('input', () => {
      lengthLabel.textContent = lengthInput.value;
      generate();
    });
    [upper, lower, numbers, symbols].forEach((el) => el.addEventListener('change', generate));
    generateBtn.addEventListener('click', generate);
    copyBtn.addEventListener('click', () => {
      result.select();
      navigator.clipboard.writeText(result.value);
    });
    generate();
  </script>
</BaseLayout>
