---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../../components/AdSlot.astro';

const tools = [
  { href: '/tools/character-counter/', title: '文字数カウンター', desc: 'ブログ・SNS投稿の文字数、単語数を即座にカウントします。' },
  { href: '/tools/password-generator/', title: 'パスワード生成ツール', desc: '安全でランダムなパスワードをその場で生成します。' },
  { href: '/tools/bmi-calculator/', title: 'BMI計算機', desc: '身長・体重からBMIと標準体重の目安を計算します。' },
  { href: '/tools/unit-converter/', title: '単位変換ツール', desc: '長さ・重さ・温度の単位をかんたん変換します。' },
  { href: '/tools/prompt-builder/', title: 'AIプロンプト作成ツール', desc: '目的・トーン・形式を選ぶだけで、ChatGPT等に使えるプロンプトを組み立てます。' },
  { href: '/tools/discount-calculator/', title: '割引・消費税計算ツール', desc: '割引後の価格や税込価格をその場で計算します。' },
  { href: '/tools/qr-code-generator/', title: 'QRコード生成ツール', desc: 'URLやテキストからQRコードをその場で生成・ダウンロードします。' },
  { href: '/tools/token-counter/', title: 'AIトークン数カウンター(概算)', desc: 'ChatGPT・Claude等に入力するテキストのトークン数を概算します。' },
  { href: '/tools/compound-interest-calculator/', title: '積立・複利計算ツール', desc: '毎月の積立額・利回り・期間から将来の資産額を試算します。' },
  { href: '/tools/ai-api-cost-calculator/', title: 'AI API料金計算ツール', desc: 'ChatGPT・Claude・Gemini等のAPI利用料金を入出力トークン数から概算します。' },
  { href: '/tools/json-formatter/', title: 'JSON整形・検証ツール', desc: '崩れたJSONやミニファイされたJSONを見やすく整形し、構文エラーを分かりやすく表示します。' },
  { href: '/tools/case-converter/', title: '文字ケース変換ツール', desc: '大文字・小文字・キャメルケース・スネークケースなど様々な文字ケースに一括変換します。' },
  { href: '/tools/markdown-previewer/', title: 'Markdownプレビューツール', desc: '入力したMarkdownテキストをその場でHTML形式にプレビュー表示する無料ツールです。' },
  { href: '/tools/base64-tool/', title: 'Base64エンコード・デコードツール', desc: '日本語を含むテキストをBase64形式に相互変換できる無料ツールです。' },
];
---
<BaseLayout title="無料ツール一覧" description="ブラウザだけで使える無料の実用ツール集">
  <h1>無料ツール</h1>
  <p>登録不要・インストール不要、ブラウザだけで使える実用ツールです。</p>

  <AdSlot label="ツール一覧ページ広告" />

  <div class="card-list">
    {tools.map((tool) => (
      <article class="card">
        <h2><a href={tool.href}>{tool.title}</a></h2>
        <p>{tool.desc}</p>
      </article>
    ))}
  </div>
</BaseLayout>
