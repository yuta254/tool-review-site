---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import AdSlot from '../../components/AdSlot.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review, allReviews: reviews },
  }));
}

const { review, allReviews } = Astro.props;
const { Content } = await render(review);

const others = allReviews.filter((r) => r.id !== review.id);
const sameCategory = others.filter((r) => r.data.category === review.data.category);
const rest = others.filter((r) => r.data.category !== review.data.category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const related = [...sameCategory, ...rest].slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: review.data.title,
  description: review.data.description,
  datePublished: review.data.pubDate.toISOString(),
  ...(review.data.updatedDate && { dateModified: review.data.updatedDate.toISOString() }),
  articleSection: review.data.category,
  keywords: review.data.tags.join(', '),
  author: { '@type': 'Organization', name: 'AI Tool Lab' },
  publisher: { '@type': 'Organization', name: 'AI Tool Lab' },
};
---
<BaseLayout title={review.data.title} description={review.data.description} jsonLd={jsonLd}>
  <p class="meta">
    <span class="tag">{review.data.category}</span>
    {review.data.pubDate.toLocaleDateString('ja-JP')}
  </p>
  <h1>{review.data.title}</h1>

  {review.data.affiliateDisclosure && <AffiliateDisclosure />}

  <article>
    <Content />
  </article>

  <AdSlot label="記事下広告" />

  {related.length > 0 && (
    <section>
      <h2>関連記事</h2>
      <div class="card-list">
        {related.map((r) => (
          <article class="card">
            <p class="meta"><span class="tag">{r.data.category}</span></p>
            <h3><a href={`/reviews/${r.id}/`}>{r.data.title}</a></h3>
            <p>{r.data.description}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <p><a href="/">&larr; 一覧に戻る</a></p>
</BaseLayout>
