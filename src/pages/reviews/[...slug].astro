---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import AdSlot from '../../components/AdSlot.astro';
import RelatedReviews from '../../components/RelatedReviews.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review, allReviews: reviews },
  }));
}

const { review, allReviews } = Astro.props;
const { Content } = await render(review);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: review.data.title,
  description: review.data.description,
  datePublished: review.data.pubDate.toISOString(),
  ...(review.data.updatedDate && { dateModified: review.data.updatedDate.toISOString() }),
  articleSection: review.data.category,
  keywords: review.data.tags.join(', '),
  author: { '@type': 'Organization', name: 'AI Tool Lab' },
  publisher: { '@type': 'Organization', name: 'AI Tool Lab' },
};
---
<BaseLayout title={review.data.title} description={review.data.description} jsonLd={jsonLd}>
  <p class="meta">
    <span class="tag">{review.data.category}</span>
    {review.data.pubDate.toLocaleDateString('ja-JP')}
  </p>
  <h1>{review.data.title}</h1>

  {review.data.affiliateDisclosure && <AffiliateDisclosure />}

  <article>
    <Content />
  </article>

  <AdSlot label="記事下広告" />

  <RelatedReviews current={review} allReviews={allReviews} />

  <p><a href="/">&larr; 一覧に戻る</a></p>
</BaseLayout>
